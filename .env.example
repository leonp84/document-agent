# Anthropic API
ANTHROPIC_API_KEY=your-key-here

# LangSmith (tracing + observability)
# Get your key at https://smith.langchain.com
LANGCHAIN_API_KEY=your-key-here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=docassist

# Local LLM (development) — OpenAI-compatible API
# Primary: MacBook Pro M5 — Gemma 4 26B (MLX, ~25 tok/sec)
LOCAL_LLM_BASE_URL=http://192.168.1.181:1234/v1
LOCAL_LLM_MODEL=gemma-4-26b-a4b-it-mlx
LOCAL_LLM_API_KEY=local

# Alternative: Windows desktop — OpenAI GPT-OSS 20B (MXFP4/RDNA4, ~59 tok/sec)
# Switch by updating LOCAL_LLM_BASE_URL and LOCAL_LLM_MODEL below
# LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
# LOCAL_LLM_MODEL=openai/gpt-oss-20b

# API authentication — share this key with testers
DOCASSIST_API_KEY=your-static-api-key-here

# App settings
ENV=development
LOG_LEVEL=INFO
# DB_PATH=data/docassist.db  # override for custom SQLite location
